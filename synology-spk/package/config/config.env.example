# Roku DS Video Tools package config.

# on-demand: proxy + subtitle watcher.
# full: proxy + subtitle watcher + background library converter.
# proxy: proxy only.
ROKU_SERVICE_MODE=on-demand

ROKU_HLS_HOST=0.0.0.0
ROKU_HLS_PORT=8099
ROKU_HLS_BASE_URL=https://your-hostname:8099
ROKU_HLS_ROOT=/volume1/@tmp/roku-hls-proxy

ROKU_HLS_SAVE_MP4=1
ROKU_HLS_REPLACE_ORIGINAL=1
ROKU_HLS_DELETE_REPLACED_ORIGINAL=1
ROKU_HLS_MP4_DIR=/volume1/video/@roku-transcodes

ROKU_SUBTITLE_POLL_SECONDS=900
ROKU_CONVERT_POLL_SECONDS=900
ROKU_CONVERT_DELETE_ORIGINAL=1

# Optional subtitle providers.
SUBDL_API_KEY=
OPEN_SUBTITLES_API_KEY=
OPEN_SUBTITLES_USERNAME=
OPEN_SUBTITLES_PASSWORD=
OPEN_SUBTITLES_LANGUAGE=en

# Optional explicit binaries. Leave blank to auto-detect.
NODE_BIN=
FFMPEG=

